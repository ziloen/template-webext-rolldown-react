{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite build --watch",
    "build": "cross-env NODE_ENV=production vite build && web-ext build -s dist/chrome -n chrome.zip",
    "dev:firefox": "cross-env NODE_ENV=development EXTENSION=firefox vite build --watch",
    "build:firefox": "cross-env NODE_ENV=production EXTENSION=firefox vite build && web-ext build -s dist/chrome -n chrome.zip",
    "start:chromium": "web-ext run -t chromium",
    "start:firefox": "web-ext run -t firefox-desktop",
    "typecheck": "tsgo -b --noEmit",
    "lint": "eslint .",
    "fmt": "oxfmt",
    "init:playwright": "playwright install chromium --with-deps",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "axios": "1.15.0",
    "clsx": "2.1.1",
    "es-toolkit": "1.45.1",
    "i18next": "26.0.1",
    "motion": "12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "17.0.4",
    "rxjs": "7.8.2",
    "serialize-error": "13.0.1",
    "typed-webext": "0.7.13",
    "uuid": "13.0.0",
    "webextension-polyfill": "0.12.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.2",
    "@fontsource-variable/fira-code": "5.2.7",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@playwright/test": "1.59.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/babel__core": "7.20.5",
    "@types/babel__preset-env": "7.10.0",
    "@types/chrome": "0.1.40",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@vitejs/devtools": "0.1.13",
    "@vitejs/plugin-react": "6.0.1",
    "@ziloen/eslint-config": "0.1.82",
    "@ziloen/tailwind-config": "2.0.21",
    "babel-plugin-annotate-module-pure": "1.0.4",
    "browserslist-to-esbuild": "2.1.1",
    "core-js": "3.49.0",
    "cross-env": "10.1.0",
    "eslint": "10.2.0",
    "oxfmt": "0.44.0",
    "playwright": "1.59.1",
    "postcss-preset-env": "11.2.1",
    "rolldown": "1.0.0-rc.15",
    "rollup-plugin-copy": "3.5.0",
    "svgo": "4.0.1",
    "tailwindcss": "4.2.2",
    "ts-lib-enhance": "1.0.22",
    "typescript": "6.0.3",
    "vite": "8.0.8",
    "web-ext": "10.1.0"
  },
  "webExt": {
    "artifactsDir": "dist",
    "run": {
      "browserConsole": false,
      "target": [
        "firefox-desktop"
      ]
    },
    "build": {
      "overwriteDest": true,
      "filename": "extension.xpi"
    }
  },
  "overrides": {
    "eslint": "$eslint",
    "typescript": "$typescript"
  }
}
