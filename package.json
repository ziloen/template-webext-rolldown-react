{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite build --watch",
    "build": "cross-env NODE_ENV=production vite build && web-ext build -s dist/chrome -n chrome.zip",
    "dev:firefox": "cross-env NODE_ENV=development EXTENSION=firefox vite build --watch",
    "build:firefox": "cross-env NODE_ENV=production EXTENSION=firefox vite build && web-ext build -s dist/chrome -n chrome.zip",
    "dev:rolldown": "cross-env NODE_ENV=development node scripts/rolldown.js",
    "build:rolldown": "cross-env NODE_ENV=production node scripts/rolldown.js && web-ext build -s dist/chrome -n chrome.zip",
    "start:chromium": "web-ext run -t chromium",
    "start:firefox": "web-ext run -t firefox-desktop",
    "typecheck": "tsgo -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "init:playwright": "playwright install chromium --with-deps",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "axios": "1.13.6",
    "clsx": "2.1.1",
    "es-toolkit": "1.45.1",
    "i18next": "25.8.18",
    "motion": "12.36.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.8",
    "rxjs": "8.0.0-alpha.14",
    "serialize-error": "13.0.1",
    "typed-webext": "0.7.10",
    "uuid": "13.0.0",
    "webextension-polyfill": "0.12.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.0",
    "@fontsource-variable/fira-code": "5.2.7",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@playwright/test": "1.58.2",
    "@rolldown/plugin-babel": "0.2.1",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/babel__core": "7.20.5",
    "@types/babel__preset-env": "7.10.0",
    "@types/chrome": "0.1.37",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/webextension-polyfill": "0.12.5",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "@vitejs/plugin-react": "6.0.1",
    "@ziloen/eslint-config": "0.1.80",
    "@ziloen/tailwind-config": "2.0.19",
    "babel-plugin-annotate-module-pure": "1.0.4",
    "browserslist-to-esbuild": "2.1.1",
    "chokidar": "5.0.0",
    "core-js": "3.48.0",
    "cross-env": "10.1.0",
    "eslint": "10.0.3",
    "playwright": "1.58.2",
    "postcss-preset-env": "11.2.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rolldown": "1.0.0-rc.5",
    "rollup-plugin-copy": "3.5.0",
    "sass-embedded": "1.98.0",
    "sonda": "0.11.1",
    "svgo": "4.0.1",
    "tailwindcss": "4.2.1",
    "ts-lib-enhance": "1.0.22",
    "typescript": "5.9.3",
    "unplugin": "3.0.0",
    "vite": "8.0.0",
    "web-ext": "10.0.0"
  },
  "webExt": {
    "artifactsDir": "dist",
    "run": {
      "browserConsole": false,
      "target": [
        "firefox-desktop"
      ]
    },
    "build": {
      "overwriteDest": true,
      "filename": "extension.xpi"
    }
  },
  "overrides": {
    "vite": "$vite",
    "eslint": "$eslint"
  }
}
